<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RentCar" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.RentCar" parent="Base.Theme.RentCar" />

    <style name="NoActiveIndicator">
        <item name="android:color">@android:color/transparent</item>
    </style>
    <style name="BottomNavActiveText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/_12ssp</item>   <!-- Active text size -->
        <item name="fontFamily">@font/generalsans_medium</item> <!-- Your font -->
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="BottomNavInactiveText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">@dimen/_12ssp</item>   <!-- Inactive text size -->
        <item name="fontFamily">@font/generalsans_regular</item>
        <item name="android:textColor">@color/nav</item>
    </style>
</resources>