<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_6sdp"
    android:background="@drawable/bg_vehicle_card"
    android:orientation="vertical">

    <!-- Car Image + Category Badge -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_120sdp">

        <ImageView
            android:id="@+id/ivCarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/dummy_image" />

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_card_bottom" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_7sdp"
            android:background="@drawable/bg_badge_orange"
            android:fontFamily="@font/general_sans_semibold"
            android:letterSpacing="0.08"
            android:paddingStart="5dp"
            android:paddingTop="2dp"
            android:paddingEnd="5dp"
            android:paddingBottom="2dp"
            android:singleLine="true"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_7ssp"
            tools:text="SUPERCAR" />

    </FrameLayout>

    <!-- Car Name + Price -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="0dp">

        <TextView
            android:id="@+id/tvCarName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/general_sans_semibold"
            android:maxLines="2"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_11sdp"
            tools:text="LAMBORGHINI HURACÁN" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_semibold"
                android:textColor="#FFE07B2B"
                android:textSize="@dimen/_13sdp"
                tools:text="$900" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_medium"
                android:text="/day"
                android:textColor="#88FFFFFF"
                android:textSize="@dimen/_8ssp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:background="#22FFFFFF" />

    <!-- Specs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="0dp">

        <!-- Row 1: Fuel | Transmission -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="3dp"
                    android:src="@drawable/ic_fuel"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvFuelType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="Petrol" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="3dp"
                    android:src="@drawable/ic_transmission"
                    app:tint="#FFE07B2B" />

                <!-- ✅ singleLine + ellipsize fixes "Automat\nic" wrap -->
                <TextView
                    android:id="@+id/tvTransmission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="Automatic" />
            </LinearLayout>

        </LinearLayout>

        <!-- Row 2: Seats | Acceleration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="3dp"
                    android:src="@drawable/ic_seat"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="2 Seater" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="3dp"
                    android:src="@drawable/ic_speed"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvAcceleration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="2.9 sec" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ACTION BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="@dimen/_10sdp">

        <TextView
            android:id="@+id/btnRentNow"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_orange"
            android:fontFamily="@font/general_sans_semibold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:singleLine="true"
            android:text="RENT NOW"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_9ssp" />

        <TextView
            android:id="@+id/btnDetails"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="@drawable/bg_border_white"
            android:fontFamily="@font/general_sans_semibold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:singleLine="true"
            android:text="DETAILS"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_9ssp" />

    </LinearLayout>

</LinearLayout>