<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_6sdp"
    android:background="@drawable/bg_vehicle_card"
    android:orientation="vertical">

    <!-- HOW IT WORKS SECTION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FF111111"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="32dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp">

        <!-- SEAMLESS PROCESS label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="@font/general_sans_medium"
            android:letterSpacing="0.2"
            android:text="SEAMLESS PROCESS"
            android:textColor="#FFE07B2B"
            android:textSize="@dimen/_9ssp" />

        <!-- HOW IT WORKS title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_semibold"
                android:text="HOW IT "
                android:textColor="#FFFFFFFF"
                android:textSize="@dimen/_24sdp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_semibold"
                android:text="WORKS"
                android:textColor="#FFE07B2B"
                android:textSize="@dimen/_24sdp" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="Experience the future of car rentals with our streamlined\nthree-step booking process designed for speed and convenience."
            android:textColor="#AAFFFFFF"
            android:textSize="@dimen/_9ssp" />

        <!-- 3 Step Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:layout_marginHorizontal="@dimen/_12sdp"
                android:paddingStart="0dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="@dimen/_250sdp"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_vehicle_card"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="@dimen/_50sdp"
                            android:layout_height="@dimen/_50sdp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="14dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_step_circle" />

                            <ImageView
                                android:layout_width="@dimen/_22sdp"
                                android:layout_height="@dimen/_22sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_location"
                                app:tint="#FFE07B2B" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_badge_orange"
                                android:fontFamily="@font/general_sans_semibold"
                                android:paddingStart="@dimen/_3sdp"
                                android:paddingTop="@dimen/_2sdp"
                                android:paddingEnd="@dimen/_3sdp"
                                android:paddingBottom="@dimen/_2sdp"
                                android:text="01"
                                android:textColor="#FFFFFFFF"
                                android:textSize="@dimen/_7ssp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/general_sans_semibold"
                            android:gravity="center"
                            android:text="CHOOSE LOCATION"
                            android:textColor="#FFFFFFFF"
                            android:textSize="@dimen/_11sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:gravity="center"
                            android:text="Select your preferred pickup point from our extensive network of premium outlets across the city."
                            android:textColor="#AAFFFFFF"
                            android:textSize="@dimen/_8ssp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="@dimen/_250sdp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:background="@drawable/bg_vehicle_card"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="@dimen/_50sdp"
                            android:layout_height="@dimen/_50sdp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="14dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_step_circle" />

                            <ImageView
                                android:layout_width="@dimen/_22sdp"
                                android:layout_height="@dimen/_22sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                app:tint="#FFE07B2B" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_badge_orange"
                                android:fontFamily="@font/general_sans_semibold"
                                android:paddingStart="@dimen/_3sdp"
                                android:paddingTop="@dimen/_2sdp"
                                android:paddingEnd="@dimen/_3sdp"
                                android:paddingBottom="@dimen/_2sdp"
                                android:text="02"
                                android:textColor="#FFFFFFFF"
                                android:textSize="@dimen/_7ssp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/general_sans_semibold"
                            android:gravity="center"
                            android:text="PICK-UP DATE"
                            android:textColor="#FFFFFFFF"
                            android:textSize="@dimen/_11sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:gravity="center"
                            android:text="Flexible scheduling options that fit your timeline. Book instantly with our real-time availability system."
                            android:textColor="#AAFFFFFF"
                            android:textSize="@dimen/_8ssp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="@dimen/_250sdp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:background="@drawable/bg_vehicle_card"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="@dimen/_50sdp"
                            android:layout_height="@dimen/_50sdp"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="14dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_step_circle" />

                            <ImageView
                                android:layout_width="@dimen/_22sdp"
                                android:layout_height="@dimen/_22sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_car"
                                app:tint="#FFE07B2B" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_badge_orange"
                                android:fontFamily="@font/general_sans_semibold"
                                android:paddingStart="@dimen/_3sdp"
                                android:paddingTop="@dimen/_2sdp"
                                android:paddingEnd="@dimen/_3sdp"
                                android:paddingBottom="@dimen/_2sdp"
                                android:text="03"
                                android:textColor="#FFFFFFFF"
                                android:textSize="@dimen/_7ssp" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/general_sans_semibold"
                            android:gravity="center"
                            android:text="BOOK YOUR CAR"
                            android:textColor="#FFFFFFFF"
                            android:textSize="@dimen/_11sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:gravity="center"
                            android:text="Confirm your reservation with a few clicks. No hidden fees, just pure performance at your fingertips."
                            android:textColor="#AAFFFFFF"
                            android:textSize="@dimen/_8ssp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>