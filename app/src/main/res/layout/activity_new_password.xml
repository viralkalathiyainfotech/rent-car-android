<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ui.auth.NewPasswordActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/generalsans_medium"
            android:includeFontPadding="false"
            android:text="@string/security"
            android:textColor="@color/orange"
            android:textSize="@dimen/_10ssp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_5sdp"
                android:fontFamily="@font/generalsans_medium"
                android:includeFontPadding="false"
                android:text="NEW"
                android:textColor="@color/white"
                android:textSize="@dimen/_35ssp" />

            <com.example.rentcar.view.OutlineTextView
                android:id="@+id/imageView23"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/password"
                android:textColor="@android:color/black"
                android:textSize="@dimen/_35ssp"
                app:outlineColor="@color/orange"
                app:outlineWidth="0.7" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10sdp"
            android:fontFamily="@font/generalsans_medium"
            android:includeFontPadding="false"
            android:text="@string/please_enter_your_new_password"
            android:textSize="@dimen/_11ssp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_25sdp"
            android:background="@drawable/bg_login_card"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:fontFamily="@font/generalsans_regular"
                    android:gravity="start"
                    android:includeFontPadding="false"
                    android:text="@string/password"
                    android:textColor="@color/themeLightText"
                    android:textSize="@dimen/_10ssp" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_35sdp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="@dimen/_6sdp">

                    <EditText
                        android:id="@+id/editPassword"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:autofillHints="password"
                        android:background="@null"
                        android:fontFamily="@font/generalsans_regular"
                        android:hint="@string/enter_new_password"
                        android:inputType="textPassword"
                        android:textColor="@color/themeLightText"
                        android:textColorHint="@color/themeLightText"
                        android:textSize="@dimen/_12ssp" />

                    <ImageView
                        android:id="@+id/icPassword"
                        android:layout_width="@dimen/_18sdp"
                        android:layout_height="@dimen/_18sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/_6sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_eye_hide" />

                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:fontFamily="@font/generalsans_regular"
                    android:gravity="start"
                    android:includeFontPadding="false"
                    android:text="@string/confirm_password"
                    android:textColor="@color/themeLightText"
                    android:textSize="@dimen/_10ssp" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_35sdp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/edit_text_bg"
                    android:paddingHorizontal="@dimen/_6sdp">

                    <EditText
                        android:id="@+id/editConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:autofillHints="password"
                        android:background="@null"
                        android:fontFamily="@font/generalsans_regular"
                        android:hint="@string/confirm_your_password"
                        android:inputType="textPassword"
                        android:textColor="@color/themeLightText"
                        android:textColorHint="@color/themeLightText"
                        android:textSize="@dimen/_12ssp" />

                    <ImageView
                        android:id="@+id/icConfirmPassword"
                        android:layout_width="@dimen/_18sdp"
                        android:layout_height="@dimen/_18sdp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/_6sdp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_eye_hide" />

                </RelativeLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/icLoginBtn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_35sdp"
                android:layout_marginTop="@dimen/_20sdp"
                android:background="@drawable/ic_button"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:indeterminateTint="@color/themeColor"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:fontFamily="@font/generalsans_semibold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/reset_password"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_13ssp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>