<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/_10sdp"
    android:background="@drawable/bg_vehicle_card"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_120sdp"
        android:background="@drawable/bg_image_top_round"
        android:clipToOutline="true"
        android:outlineProvider="background">

        <ImageView
            android:id="@+id/ivCarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/dummy_image" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/_30sdp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_card_bottom" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_7sdp
            android:fontFamily="@font/general_sans_semibold"
            android:letterSpacing="0.08"
            android:paddingStart="@dimen/_3sdp"
            android:paddingTop="@dimen/_1sdp"
            android:paddingEnd="@dimen/_3sdp"
            android:paddingBottom="@dimen/_1sdp"
            android:singleLine="true"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_7ssp"
            tools:text="SUPERCAR" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/_4sdp"
        android:paddingTop="@dimen/_4sdp"
        android:paddingEnd="@dimen/_4sdp"
        android:paddingBottom="0dp">

        <TextView
            android:id="@+id/tvCarName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/general_sans_semibold"
            android:maxLines="2"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_11sdp"
            tools:text="LAMBORGHINI HURACÁN" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_semibold"
                android:textColor="#FFE07B2B"
                android:textSize="@dimen/_13sdp"
                tools:text="$900" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_medium"
                android:text="/day"
                android:textColor="#88FFFFFF"
                android:textSize="@dimen/_8ssp" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/_1sdp"
        android:layout_marginStart="@dimen/_4sdp"
        android:layout_marginTop="@dimen/_3sdp"
        android:layout_marginEnd="@dimen/_4sdp"
        android:background="#22FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/_4sdp"
        android:paddingTop="@dimen/_3sdp"
        android:paddingEnd="@dimen/_4sdp"
        android:paddingBottom="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_2sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:src="@drawable/ic_fuel"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvFuelType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="Petrol" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:src="@drawable/ic_transmission"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvTransmission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="Automatic" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:src="@drawable/ic_seat"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="2 Seater" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/_11sdp"
                    android:layout_height="@dimen/_11sdp"
                    android:layout_marginEnd="@dimen/_2sdp"
                    android:src="@drawable/ic_speed"
                    app:tint="#FFE07B2B" />

                <TextView
                    android:id="@+id/tvAcceleration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/general_sans_medium"
                    android:singleLine="true"
                    android:textColor="#AAFFFFFF"
                    android:textSize="@dimen/_9ssp"
                    tools:text="2.9 sec" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_4sdp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/_4sdp"
        android:paddingEnd="@dimen/_4sdp"
        android:paddingBottom="@dimen/_10sdp">

        <TextView
            android:id="@+id/btnRentNow"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="@dimen/_3sdp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_orange"
            android:fontFamily="@font/general_sans_semibold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:singleLine="true"
            android:text="RENT NOW"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_9ssp" />

        <TextView
            android:id="@+id/btnDetails"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="@drawable/bg_border_white"
            android:fontFamily="@font/general_sans_semibold"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:singleLine="true"
            android:text="DETAILS"
            android:textColor="#FFFFFFFF"
            android:textSize="@dimen/_9ssp" />

    </LinearLayout>

</LinearLayout>