<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/themeColor"
    tools:context=".base.fragment.HomeFragment">

    <FrameLayout
        android:id="@+id/frameLay"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_250sdp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivCarBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.85"
            android:scaleType="centerCrop"
            android:src="@drawable/dummy_image" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_hero_overlay" />

        <View
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_gravity="bottom"
            android:background="#CC111111" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="14dp"
            android:paddingEnd="20dp"
            android:paddingBottom="0dp">

            <!-- "04 | ELECTRIC FUTURE" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBadgeNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:text="04"
                    android:textColor="#FFE07B2B"
                    android:textSize="10sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="#88FFFFFF" />

                <TextView
                    android:id="@+id/tvBadgeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.15"
                    android:text="ELECTRIC FUTURE"
                    android:textColor="#CCFFFFFF"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeadline1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="0.88"
                android:text="SILENT"
                android:textColor="#FFFFFFFF"
                android:textSize="52sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHeadline2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.01"
                android:shadowColor="#FFE07B2B"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="1"
                android:text="REVOLUTION"
                android:textColor="#00000000"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:lineSpacingMultiplier="1.4"
                android:text="The future is here. Sustainable power meets instant torque in our premium electric vehicle category."
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="0dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnExploreNow"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_btn_orange"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:letterSpacing="0.12"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="EXPLORE NOW  →"
                    android:textColor="#FFFFFFFF"
                    android:textSize="10sp" />

                <LinearLayout
                    android:id="@+id/btnEcoPerformance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_border"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/flVolKnob"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="16dp">

                        <com.example.rentcar.base.utils.KnobView
                            android:id="@+id/rotaryKnob2"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center" />

                    </FrameLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:letterSpacing="0.10"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="ECO-PERFORMANCE"
                        android:textColor="#DDFFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_shield"
                        app:tint="#FFE07B2B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:text="FULL INSURANCE"
                        android:textColor="#AAFFFFFF"
                        android:textSize="8sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_location"
                        app:tint="#FFE07B2B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:text="ANYWHERE DELIVERY"
                        android:textColor="#AAFFFFFF"
                        android:textSize="8sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_car"
                        app:tint="#FFE07B2B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.10"
                        android:text="LATEST MODELS"
                        android:textColor="#AAFFFFFF"
                        android:textSize="8sp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="4dp"
            android:background="#FFE07B2B" />


    </FrameLayout>

    

</RelativeLayout>