<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ui.activity.auth.CreateAccountActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/_15sdp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/general_sans_medium"
                android:includeFontPadding="false"
                android:text="@string/join_carrental"
                android:textColor="@color/orange"
                android:textSize="@dimen/_10ssp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/_5sdp"
                    android:fontFamily="@font/general_sans_medium"
                    android:includeFontPadding="false"
                    android:text="@string/create"
                    android:textColor="@color/themeLightText"
                    android:textSize="@dimen/_30ssp" />

                <com.example.rentcar.view.OutlineTextView
                    android:id="@+id/imageView23"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/account"
                    android:textColor="@android:color/black"
                    android:textSize="@dimen/_30ssp"
                    app:outlineColor="@color/orange"
                    app:outlineWidth="0.7" />


            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:fontFamily="@font/general_sans_medium"
                android:includeFontPadding="false"
                android:text="@string/join_carrental_to_book_your_dream_car"
                android:textSize="@dimen/_9ssp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_35sdp"
                android:layout_marginBottom="@dimen/_20sdp"
                android:background="@drawable/bg_login_card"
                android:gravity="center"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFirstName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/general_sans_regular"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:text="FIRST NAME"
                            android:textColor="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <EditText
                            android:id="@+id/editUsername"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_35sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:autofillHints="name"
                            android:background="@drawable/edit_text_bg"
                            android:fontFamily="@font/general_sans_regular"
                            android:hint="Enter your first name"
                            android:includeFontPadding="false"
                            android:inputType="textEmailAddress"
                            android:paddingHorizontal="@dimen/_6sdp"
                            android:textColor="@color/themeLightText"
                            android:textColorHint="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_10sdp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvLastName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/general_sans_regular"
                            android:gravity="start"
                            android:includeFontPadding="false"
                            android:text="LAST NAME"
                            android:textColor="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <EditText
                            android:id="@+id/editLatName"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_35sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:background="@drawable/edit_text_bg"
                            android:fontFamily="@font/general_sans_regular"
                            android:hint="Enter your last name"
                            android:includeFontPadding="false"
                            android:inputType="textEmailAddress"
                            android:paddingHorizontal="@dimen/_6sdp"
                            android:textColor="@color/themeLightText"
                            android:textColorHint="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/general_sans_regular"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:text="@string/email_address"
                        android:textColor="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />

                    <EditText
                        android:id="@+id/editEmail"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/edit_text_bg"
                        android:fontFamily="@font/general_sans_regular"
                        android:hint="Enter your email"
                        android:includeFontPadding="false"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="@dimen/_6sdp"
                        android:textColor="@color/themeLightText"
                        android:textColorHint="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/general_sans_regular"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:text="PHONE NUMBER"
                        android:textColor="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />

                    <EditText
                        android:id="@+id/editPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/edit_text_bg"
                        android:fontFamily="@font/general_sans_regular"
                        android:hint="Enter your phone number"
                        android:includeFontPadding="false"
                        android:inputType="phone"
                        android:paddingHorizontal="@dimen/_6sdp"
                        android:textColor="@color/themeLightText"
                        android:textColorHint="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/general_sans_regular"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:text="DRIVING LICENSE NUMBER"
                        android:textColor="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />

                    <EditText
                        android:id="@+id/editDrivingLicense"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:autofillHints="emailAddress"
                        android:background="@drawable/edit_text_bg"
                        android:fontFamily="@font/general_sans_regular"
                        android:hint="Enter your driving license number"
                        android:includeFontPadding="false"
                        android:inputType="none"
                        android:paddingHorizontal="@dimen/_6sdp"
                        android:textColor="@color/themeLightText"
                        android:textColorHint="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:fontFamily="@font/general_sans_regular"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:text="Password"
                        android:textColor="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="@dimen/_6sdp">

                        <EditText
                            android:id="@+id/editPassword"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_35sdp"
                            android:autofillHints="password"
                            android:background="@null"
                            android:fontFamily="@font/general_sans_regular"
                            android:hint="Create Password"
                            android:includeFontPadding="false"
                            android:inputType="textPassword"
                            android:textColor="@color/themeLightText"
                            android:textColorHint="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <ImageView
                            android:id="@+id/icPassword"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/_6sdp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_eye_hide" />

                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:fontFamily="@font/general_sans_regular"
                        android:gravity="start"
                        android:includeFontPadding="false"
                        android:text="CONFIRM PASSWORD"
                        android:textColor="@color/themeLightText"
                        android:textSize="@dimen/_10ssp" />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:background="@drawable/edit_text_bg"
                        android:paddingHorizontal="@dimen/_6sdp">

                        <EditText
                            android:id="@+id/editConfimrPassword"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_35sdp"
                            android:autofillHints="password"
                            android:background="@null"
                            android:fontFamily="@font/general_sans_regular"
                            android:hint="Confrim Password"
                            android:inputType="textPassword"
                            android:textColor="@color/themeLightText"
                            android:textColorHint="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <ImageView
                            android:id="@+id/icConfirmPassword"
                            android:layout_width="@dimen/_15sdp"
                            android:layout_height="@dimen/_15sdp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="@dimen/_6sdp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_eye_hide" />

                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:layout_weight="1"
                        android:gravity="start"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatCheckBox
                            android:id="@+id/checkBox"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            app:buttonTint="@color/checkbox" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_3sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="I agree to the"
                            android:textColor="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <TextView
                            android:id="@+id/textTerms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_3sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="Terms of Service"
                            android:textColor="@color/orange"
                            android:textSize="@dimen/_10ssp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_3sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="and"
                            android:textColor="@color/themeLightText"
                            android:textSize="@dimen/_10ssp" />

                        <TextView
                            android:id="@+id/textPrivacy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_3sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="Privacy Policy"
                            android:textColor="@color/orange"
                            android:textSize="@dimen/_10ssp" />
                    </LinearLayout>
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/icLoginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_35sdp"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:background="@drawable/ic_button"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:indeterminateTint="@color/themeColor"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/icRegisterBtn"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_44sdp"
                        android:background="@drawable/ic_button"
                        android:fontFamily="@font/general_sans_medium"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="Create Account"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_16ssp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:background="@drawable/border" />

                <LinearLayout
                    android:id="@+id/IcRegisterNow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:layout_marginBottom="@dimen/_15sdp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="Already have an account?"
                            android:textColor="#A1A1A1"
                            android:textSize="@dimen/_10ssp" />

                        <TextView
                            android:id="@+id/btnSignIn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:fontFamily="@font/general_sans_regular"
                            android:includeFontPadding="false"
                            android:text="Sign In"
                            android:textColor="@color/orange"
                            android:textSize="@dimen/_13ssp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>